SECRET_KEY=replace-with-a-strong-random-secret

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ener_quote
DB_USER=postgres
DB_PASSWORD=change-me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=2
REDIS_PASSWORD=

# SMTP for OTP / password emails
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM_NAME=EnerQuote
# false means SMTPS (465), true means STARTTLS (587)
SMTP_USE_TLS=false

# Optional backward compatibility key
SMTP_SERVER=${SMTP_HOST}

# --- OAuth (Google / Microsoft login) ---
# Google Cloud Console OAuth 2.0 client IDs (comma-separated) trusted as ID token audiences.
GOOGLE_OAUTH_CLIENT_IDS=
# Azure App Registration Application (client) ID (same as Flutter --dart-define MICROSOFT_OAUTH_CLIENT_ID).
MICROSOFT_OAUTH_CLIENT_ID=

# --- Paddle Billing ---
# Server API (transactions, webhooks)
PADDLE_API_KEY=
PADDLE_PRICE_ID=
PADDLE_WEBHOOK_SECRET=
# sandbox | production (also drives API host and Paddle.js environment)
PADDLE_ENVIRONMENT=sandbox

# Paddle.js embedded checkout (/api/v1/payment/checkout-ui)
# Dashboard → Developer tools → Client-side token (not the secret API key)
PADDLE_CLIENT_TOKEN=
# Redirect URLs after checkout events (Flutter WebView should intercept; include _ptxn= if needed)
PADDLE_CHECKOUT_SUCCESS_REDIRECT_URL=https://api.dothings.one/?_ptxn=completed
PADDLE_CHECKOUT_CLOSED_REDIRECT_URL=https://api.dothings.one/?_ptxn=cancelled
