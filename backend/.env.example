SECRET_KEY=replace-with-a-strong-random-secret

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ener_quote
DB_USER=postgres
DB_PASSWORD=change-me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=2
REDIS_PASSWORD=

# SMTP for OTP / password emails
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM_NAME=EnerQuote
# false means SMTPS (465), true means STARTTLS (587)
SMTP_USE_TLS=false

# Optional backward compatibility key
SMTP_SERVER=${SMTP_HOST}
